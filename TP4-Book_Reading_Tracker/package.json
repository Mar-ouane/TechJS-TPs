{
  "name": "book-reading-tracker",
  "version": "1.0.0",
  "description": "Book Reading Tracker - Track your reading journey (TypeScript)",
  "main": "dist/server.js",
  "scripts": {
    "build:server": "tsc",
    "build:client": "tsc -p tsconfig.client.json",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "dev": "npm run build && node dist/server.js",
    "seed": "npx ts-node src/seed.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
